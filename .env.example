# --- DeepSeek-V4-Flash (OpenAI-compatible) ---
DEEPSEEK_API_KEY=your_key_here
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_TIMEOUT=60
DEEPSEEK_MAX_RETRIES=3

# --- long-term backend: vector | mem0 | lightrag | letta | a "+"-list (vector+mem0) ---
LONG_TERM_BACKEND=vector
ROUTER_MERGE=interleave              # cross-backend read merge: interleave | score
ROUTER_WRITE=all                     # cross-backend write fan-out: all | first
LIGHTRAG_WORKING_DIR=.data/lightrag   # per-user knowledge graph (lightrag backend)
# mem0 backend (local stack: deepseek + HF embeddings + embedded qdrant)
MEM0_EMBEDDER_PROVIDER=huggingface
MEM0_EMBEDDING_DIMS=384               # match your embedder (all-MiniLM-L6-v2 = 384)
MEM0_VECTOR_PATH=.data/mem0_qdrant

# --- short-term store: memory | redis ---
SHORT_TERM_STORE=memory
SHORT_TERM_MAX_TURNS=12
REDIS_URL=redis://localhost:6379/0
REDIS_NAMESPACE=agentmem:st

# --- embeddings (vector backend): auto | hash | sentence_transformers | openai ---
EMBEDDING_PROVIDER=auto
EMBEDDING_MODEL=all-MiniLM-L6-v2
# EMBEDDING_BASE_URL=     # for EMBEDDING_PROVIDER=openai
# EMBEDDING_API_KEY=

# --- vector backend durability (empty = in-memory only) ---
# VECTOR_PERSIST_PATH=.data/memories.json

# --- consolidation: promote short->long every N user turns ---
CONSOLIDATE_EVERY=4
CONSOLIDATION_ASYNC=0                 # 1 = run extraction on a background worker (non-blocking add_turn)
